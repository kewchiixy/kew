function openCustom(){npVal='0';updateNP();openMod('mCustom');}
function np(k){
  if(k==='d'){npVal=npVal.slice(0,-1)||'0';}
  else if(npVal==='0'){if(k!=='0')npVal=k;}
  else{if(npVal.length<7)npVal+=k;}
  updateNP();
}
function updateNP(){document.getElementById('ndisp').textContent=fmt(parseInt(npVal)||0);}
function npConfirm(){
  const p=parseInt(npVal)||0;
  if(!p){alert('กรุณากรอกราคาที่มากกว่า 0');return;}
  addToCart(p,`สินค้า ฿${fmt(p)}`);
