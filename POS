<script>
// ==================== CONSTANTS ====================
const BANKNOTES = [1000, 500, 100, 50, 20];
const COINS     = [10, 5, 2, 1];
const ALL_D     = [...BANKNOTES, ...COINS];
// เพิ่ม 1 และ 2 บาทเข้าในราคายอดฮิตด้วย
const PRICES    = [1,2,5,10,15,20,25,30,40,50,60,80,100,150,200,300,500,1000];

// ==================== STATE ====================
let cart = [];
let paymentType = 'cash';
let cashD = {};
let useManual = false;
let npVal = '0';
let currentTab = 'today';
let dbReady = false;
let idbDB = null;

ALL_D.forEach(d => cashD[d] = 0);

// ==================== INDEXEDDB SETUP ====================
// IDB = second layer of protection beyond localStorage
// Stores both transaction records AND the current cart state

const IDB_NAME = 'pos_idb';
const IDB_VER  = 1;
const STORE_RECORDS = 'records';
const STORE_CART    = 'cart_state';

function openIDB() {
  return new Promise((resolve, reject) => {
    const req = indexedDB.open(IDB_NAME, IDB_VER);
    req.onupgradeneeded = e => {
      const db = e.target.result;
      if (!db.objectStoreNames.contains(STORE_RECORDS)) {
        const s = db.createObjectStore(STORE_RECORDS, {keyPath:'id'});
        s.createIndex('time','time',{unique:false});
      }
      if (!db.objectStoreNames.contains(STORE_CART)) {
        db.createObjectStore(STORE_CART, {keyPath:'key'});
      }
    };
    req.onsuccess = e => { idbDB = e.target.result; dbReady = true; updateBackupDot(true); resolve(idbDB); };
    req.onerror   = e => { console.warn('IDB failed:', e); updateBackupDot(false); resolve(null); };
  });
}

function updateBackupDot(ok) {
  const dot = document.getElementById('backupDot');
  if (dot) dot.style.background = ok ? '#4ade80' : '#f87171';
}

function idbSaveRecord(rec) {
  if (!idbDB) return;
  try {
    const tx = idbDB.transaction(STORE_RECORDS, 'readwrite');
    tx.objectStore(STORE_RECORDS).put(rec);
  } catch(e) { console.warn('IDB save record fail:', e); }
}

function idbSaveCart() {
  if (!idbDB) return;
  try {
    const state = {
      key: 'current',
      cart: JSON.parse(JSON.stringify(cart)),
      paymentType,
      cashD: {...cashD},
      useManual,
      savedAt: new Date().toISOString()
    };
    const tx = idbDB.transaction(STORE_CART, 'readwrite');
    tx.objectStore(STORE_CART).put(state);
  } catch(e) { console.warn('IDB save cart fail:', e); }
}

function idbRestoreCart() {
  if (!idbDB) return;
  try {
    const tx = idbDB.transaction(STORE_CART, 'readonly');
    const req = tx.objectStore(STORE_CART).get('current');
    req.onsuccess = e => {
      const s = e.target.result;
      if (!s || !s.cart || !s.cart.length) return;
      // Only restore if cart is currently empty (fresh page load)
      if (cart.length > 0) return;
      cart = s.cart;
      paymentType = s.paymentType || 'cash';
      cashD = s.cashD || {};
      ALL_D.forEach(d => { if (cashD[d] === undefined) cashD[d] = 0; });
      useManual = s.useManual || false;
      renderCart();
      setPayment(paymentType);
      renderDenoms();
      calcChange();
      if (cart.length > 0) {
        showToast(`🔄 กู้คืนตะกร้า ${cart.length} รายการจากการบันทึกอัตโนมัติ`);
      }
    };
  } catch(e) { console.warn('IDB restore fail:', e); }
}

// Also migrate any IDB records to localStorage on load
function idbSyncToLocalStorage() {
  if (!idbDB) return;
  try {
    const tx = idbDB.transaction(STORE_RECORDS, 'readonly');
    const req = tx.objectStore(STORE_RECORDS).getAll();
    req.onsuccess = e => {
      const recs = e.target.result || [];
      // Group by day and merge into localStorage
      const byDay = {};
      recs.forEach(r => {
        const dk = 'pos_' + r.time.slice(0,10);
        if (!byDay[dk]) byDay[dk] = [];
        byDay[dk].push(r);
      });
      Object.entries(byDay).forEach(([k, arr]) => {
        const existing = JSON.parse(localStorage.getItem(k)||'[]');
        const existingIds = new Set(existing.map(r => r.id));
        const newOnes = arr.filter(r => !existingIds.has(r.id));
        if (newOnes.length) {
          const merged = [...existing, ...newOnes];
          localStorage.setItem(k, JSON.stringify(merged));
        }
      });
    };
  } catch(e) { console.warn('IDB sync fail:', e); }
}

// ==================== AUTO-SAVE CART ====================
// Saves cart state every 5 seconds to both localStorage and IDB
function autoSaveCart() {
  try {
    const state = {
      cart: JSON.parse(JSON.stringify(cart)),
      paymentType,
      cashD: {...cashD},
      useManual,
      savedAt: new Date().toISOString()
    };
    localStorage.setItem('pos_cart_autosave', JSON.stringify(state));
    idbSaveCart();
  } catch(e) { console.warn('autosave fail:', e); }
}

function restoreCartFromLocalStorage() {
  try {
    const raw = localStorage.getItem('pos_cart_autosave');
    if (!raw) return false;
    const s = JSON.parse(raw);
    if (!s.cart || !s.cart.length) return false;
    cart = s.cart;
    paymentType = s.paymentType || 'cash';
    cashD = s.cashD || {};
    ALL_D.forEach(d => { if (cashD[d] === undefined) cashD[d] = 0; });
    useManual = s.useManual || false;
    return true;
  } catch(e) { return false; }
}

// ==================== INIT ====================
async function init() {
  buildPriceGrid();
  buildDenomGrids();

  // Open IDB first
  await openIDB();

  // Restore cart from localStorage first (faster)
  const restored = restoreCartFromLocalStorage();
  if (restored && cart.length > 0) {
    renderCart();
    setPayment(paymentType);
    renderDenoms();
    calcChange();
    showToast(`🔄 กู้คืนตะกร้า ${cart.length} รายการ`);
  } else {
    renderCart();
    setPayment('cash');
  }

  // Then try IDB (may have more recent data if localStorage was cleared)
  if (!restored) setTimeout(() => idbRestoreCart(), 500);

  // Sync IDB → localStorage in background
  setTimeout(() => idbSyncToLocalStorage(), 1000);

  // Auto-save every 5 seconds
  setInterval(autoSaveCart, 5000);

  updateClock();
  setInterval(updateClock, 1000);

  const today = new Date().toISOString().slice(0,10);
  const month = today.slice(0,7);
  document.getElementById('dayPicker').value = today;
  document.getElementById('monthPicker').value = month;
}

function updateClock() {
  const n = new Date();
  document.getElementById('clock').textContent =
    n.toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false});
}

// ==================== PRICE GRID ====================
function buildPriceGrid() {
  const g = document.getElementById('priceGrid');
  g.innerHTML = '';
  PRICES.forEach(p => {
    const b = document.createElement('button');
    b.className = 'pbtn' + (p >= 500 ? ' hi' : '');
    b.innerHTML = `<span>${fmt(p)}</span><span class="sub">บาท</span>`;
    b.onclick = () => addToCart(p);
    g.appendChild(b);
  });
  const c = document.createElement('button');
  c.className = 'pcustom';
  c.innerHTML = `✏️ ระบุราคาเอง`;
  c.onclick = openCustom;
  g.appendChild(c);
}

// ==================== CART ====================
function addToCart(price, label) {
  const name = label || `สินค้า ฿${fmt(price)}`;
  const ex = cart.find(i => i.name === name && i.price === price);
  if (ex) { ex.qty++; }
  else { cart.push({id: Date.now()+Math.random(), name, price, qty:1}); }
  renderCart();
  autoSaveCart();
}

function changeQty(id, d) {
  const it = cart.find(i => i.id === id);
  if (!it) return;
  it.qty += d;
  if (it.qty <= 0) cart = cart.filter(i => i.id !== id);
  renderCart();
  autoSaveCart();
}

function removeItem(id) {
  cart = cart.filter(i => i.id !== id);
  renderCart();
  autoSaveCart();
}

function clearCart() {
  if (!cart.length) return;
  cart = [];
  resetCash();
  renderCart();
  calcChange();
  // Clear saved cart
  try { localStorage.removeItem('pos_cart_autosave'); } catch(e){}
  if (idbDB) {
    try {
      const tx = idbDB.transaction(STORE_CART, 'readwrite');
      tx.objectStore(STORE_CART).delete('current');
    } catch(e){}
  }
}

function getTotal() {
  return cart.reduce((s,i) => s + i.price * i.qty, 0);
}

function renderCart() {
  const list = document.getElementById('cartList');
  const total = getTotal();
  const count = cart.reduce((s,i) => s + i.qty, 0);
  document.getElementById('totalAmt').textContent = fmt(total);
  document.getElementById('cartCount').textContent = count;
  document.getElementById('checkoutBtn').disabled = !cart.length;
  calcChange();
  if (!cart.length) {
    list.innerHTML = `<div class="cart-empty"><div class="ei">🛒</div><p>ยังไม่มีสินค้า</p><p class="es">กดปุ่มราคาด้านซ้ายเพื่อเพิ่ม</p></div>`;
    return;
  }
  list.innerHTML = cart.map(it => `
    <div class="citem">
      <div class="citem-info">
        <div class="citem-name">${esc(it.name)}</div>
        <div class="citem-price">฿${fmt(it.price)} × ${it.qty} = ฿${fmt(it.price*it.qty)}</div>
      </div>
      <div class="cqty">
        <button class="qbtn" onclick="changeQty(${it.id},-1)">−</button>
        <span class="qnum">${it.qty}</span>
        <button class="qbtn" onclick="changeQty(${it.id},1)">+</button>
      </div>
      <div class="citem-tot">฿${fmt(it.price*it.qty)}</div>
      <button class="rmbtn" onclick="removeItem(${it.id})">✕</button>
    </div>
  `).join('');
}

// ==================== PAYMENT ====================
function setPayment(type) {
  paymentType = type;
  document.getElementById('btnCash').className = 'ptbtn' + (type==='cash' ? ' ac' : '');
  document.getElementById('btnTrf').className  = 'ptbtn' + (type==='transfer' ? ' at' : '');
  document.getElementById('cashSection').style.display    = type==='cash' ? '' : 'none';
  document.getElementById('transferSection').style.display= type==='transfer' ? '' : 'none';
  calcChange();
}

// ==================== DENOMINATION ====================
function buildDenomGrids() {
  const bg = document.getElementById('bankGrid');
  const cg = document.getElementById('coinGrid');
  BANKNOTES.forEach(d => bg.appendChild(makeDBtn(d,'💵','ใบ')));
  COINS.forEach(d => cg.appendChild(makeDBtn(d,'🪙','เหรียญ')));
}

function makeDBtn(val, icon, type) {
  const b = document.createElement('div');
  b.className = 'dbtn';
  b.innerHTML = `
    <div class="dv">${val >= 1000 ? '1K' : fmt(val)}</div>
    <div class="dt">${type}</div>
    <div class="dbadge" id="badge_${val}">0</div>
  `;
  b.onclick = () => addDenom(val);
  return b;
}

function addDenom(val) { cashD[val]++; renderDenoms(); calcChange(); }
function subDenom(val) { if (cashD[val]>0){cashD[val]--;renderDenoms();calcChange();} }
function resetCash() {
  ALL_D.forEach(d => cashD[d]=0);
  document.getElementById('manualInput').value='';
  useManual=false;
  const inp=document.getElementById('manualInput');
  inp.style.display='none';
  document.getElementById('manualToggle').textContent='✏️ หรือพิมพ์จำนวนเงินเองด้วยตัวเลข';
  document.getElementById('bankGrid').style.opacity='';
  document.getElementById('bankGrid').style.pointerEvents='';
  document.getElementById('coinGrid').style.opacity='';
  document.getElementById('coinGrid').style.pointerEvents='';
  renderDenoms();
}

function getTotalReceived() {
  if (useManual) return parseFloat(document.getElementById('manualInput').value)||0;
  return ALL_D.reduce((s,d)=>s+d*cashD[d],0);
}

function renderDenoms() {
  ALL_D.forEach(d => {
    const b = document.getElementById('badge_'+d);
    if (!b) return;
    const cnt = cashD[d];
    b.textContent = cnt;
    b.className = 'dbadge'+(cnt>0?' show':'');
  });
  const bk = document.getElementById('denomBreakdown');
  const rr = document.getElementById('receivedRow');
  const active = ALL_D.filter(d=>cashD[d]>0);
  if (!active.length || useManual) {
    bk.innerHTML = useManual?'':'<div class="denom-empty">กดแบงค์/เหรียญด้านบนเพื่อเพิ่ม</div>';
    rr.style.display='none';
    return;
  }
  const total = getTotalReceived();
  rr.style.display='flex';
  document.getElementById('receivedTotal').textContent='฿'+fmt(total);
  bk.innerHTML='<div class="sdivider"></div>'+active.map(d=>{
    const cnt=cashD[d];
    const type=BANKNOTES.includes(d)?'ใบ':'เหรียญ';
    const icon=BANKNOTES.includes(d)?'💵':'🪙';
    return `
      <div class="denom-row">
        <div class="denom-row-left">
          <span>${icon}</span>
          <div class="denom-row-info">฿${fmt(d)} × ${cnt} ${type}</div>
        </div>
        <span class="denom-row-total">= ฿${fmt(d*cnt)}</span>
        <button class="denom-row-minus" onclick="subDenom(${d})">−</button>
      </div>
    `;
  }).join('');
}

function toggleManual() {
  useManual=!useManual;
  const inp=document.getElementById('manualInput');
  const tog=document.getElementById('manualToggle');
  inp.style.display=useManual?'block':'none';
  tog.textContent=useManual?'🔢 กลับไปใช้ปุ่มแบงค์/เหรียญ':'✏️ หรือพิมพ์จำนวนเงินเองด้วยตัวเลข';
  document.getElementById('bankGrid').style.opacity=useManual?'0.3':'';
  document.getElementById('bankGrid').style.pointerEvents=useManual?'none':'';
  document.getElementById('coinGrid').style.opacity=useManual?'0.3':'';
  document.getElementById('coinGrid').style.pointerEvents=useManual?'none':'';
  renderDenoms();
  calcChange();
}

function calcChange() {
  if (paymentType==='transfer') return;
  const received=getTotalReceived();
  const total=getTotal();
  const change=received-total;
  const box=document.getElementById('changeBox');
  const val=document.getElementById('changeVal');
  if (received===0){
    box.className='change-box zero';val.textContent='฿0';
  } else if (change<0){
    box.className='change-box ins';val.textContent=`ขาด ฿${fmt(Math.abs(change))}`;
  } else {
    box.className='change-box';val.textContent=`฿${fmt(change)}`;
  }
}

// ==================== CHECKOUT ====================
function checkout() {
  if (!cart.length) return;
  const total=getTotal();
  const received=paymentType==='cash'?getTotalReceived():total;
  if (paymentType==='cash'&&received<total){
    alert('⚠️ เงินที่รับมายังไม่พอ กรุณาเพิ่มแบงค์/เหรียญหรือกรอกเงินให้ครบ');
    return;
  }
  const denomSnap={};
  ALL_D.forEach(d=>denomSnap[d]=cashD[d]);
  const rec={
    id: Date.now(),
    time: new Date().toISOString(),
    items: cart.map(i=>({...i})),
    total, paymentType, received,
    change: paymentType==='cash'?received-total:0,
    cashDenominations: paymentType==='cash'?denomSnap:null,
    useManual,
  };
  saveRecord(rec);
  idbSaveRecord(rec); // dual save to IDB
  cart=[];
  resetCash();
  renderCart();
  calcChange();
  // Clear autosave
  try{ localStorage.removeItem('pos_cart_autosave'); }catch(e){}
  if (idbDB) {
    try{
      const tx=idbDB.transaction(STORE_CART,'readwrite');
      tx.objectStore(STORE_CART).delete('current');
    }catch(e){}
  }
  showToast(`✅ บันทึกแล้ว ฿${fmt(total)} (${paymentType==='cash'?'เงินสด':'เงินโอน'})`);
}

// ==================== STORAGE (localStorage) ====================
function dayKey(d){ return 'pos_'+(d||new Date().toISOString().slice(0,10)); }

function saveRecord(rec){
  const k=dayKey(rec.time.slice(0,10));
  const arr=JSON.parse(localStorage.getItem(k)||'[]');
  arr.push(rec);
  localStorage.setItem(k,JSON.stringify(arr));
}

function getAllPOSKeys(){
  return Object.keys(localStorage)
    .filter(k=>/^pos_\d{4}-\d{2}-\d{2}$/.test(k))
    .sort().reverse();
}

function getRecords(prefix){
  const keys=getAllPOSKeys().filter(k=>{
    const d=k.slice(4);
    return !prefix||d.startsWith(prefix);
  });
  const recs=[];
  keys.forEach(k=>{
    const arr=JSON.parse(localStorage.getItem(k)||'[]');
    arr.forEach(r=>recs.push({...r,_dateKey:k.slice(4)}));
  });
  return recs.sort((a,b)=>new Date(b.time)-new Date(a.time));
}

// ==================== HISTORY MODAL ====================
function openHistory(){ openSummary(); }

function openSummary(){
  currentTab='today';
  document.querySelectorAll('.htab').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab_today').classList.add('active');
  document.getElementById('datePickerRow').style.display='none';
  document.getElementById('monthPickerRow').style.display='none';
  renderHistory();
  openMod('mHistory');
}

function switchTab(tab){
  currentTab=tab;
  document.querySelectorAll('.htab').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab_'+tab).classList.add('active');
  document.getElementById('datePickerRow').style.display=tab==='day'?'flex':'none';
  document.getElementById('monthPickerRow').style.display=tab==='month'?'flex':'none';
  renderHistory();
}

function renderHistory(){
  const tab=currentTab;
  const today=new Date().toISOString().slice(0,10);
  let prefix='';
  if (tab==='today') prefix=today;
  else if (tab==='day') prefix=document.getElementById('dayPicker').value;
  else if (tab==='month') prefix=document.getElementById('monthPicker').value;

  const recs=getRecords(prefix);
  const content=document.getElementById('historyContent');
  if (!recs.length){
    content.innerHTML=`<div class="hempty">📭 ไม่มีข้อมูลในช่วงเวลานี้</div>`;
    return;
  }

  const totalAll=recs.reduce((s,r)=>s+r.total,0);
  const totalCash=recs.filter(r=>r.paymentType==='cash').reduce((s,r)=>s+r.total,0);
  const totalTrf=recs.filter(r=>r.paymentType==='transfer').reduce((s,r)=>s+r.total,0);
  const cntCash=recs.filter(r=>r.paymentType==='cash').length;
  const cntTrf=recs.filter(r=>r.paymentType==='transfer').length;

  let html=`
    <div class="scards">
      <div class="scard tot"><div class="scard-lbl">ยอดรวมทั้งหมด</div><div class="scard-amt">฿${fmt(totalAll)}</div><div class="scard-sub">${recs.length} รายการ</div></div>
      <div class="scard csh"><div class="scard-lbl">เงินสด</div><div class="scard-amt">฿${fmt(totalCash)}</div><div class="scard-sub">${cntCash} รายการ</div></div>
      <div class="scard trf"><div class="scard-lbl">เงินโอน</div><div class="scard-amt">฿${fmt(totalTrf)}</div><div class="scard-sub">${cntTrf} รายการ</div></div>
    </div>
  `;

  // Denom summary for cash records
  const cashRecs=recs.filter(r=>r.paymentType==='cash'&&r.cashDenominations&&!r.useManual);
  if (cashRecs.length){
    const totD={};
    ALL_D.forEach(d=>totD[d]=0);
    cashRecs.forEach(r=>{
      ALL_D.forEach(d=>{ totD[d]+=(r.cashDenominations[d]||0); });
    });
    const anyD=ALL_D.some(d=>totD[d]>0);
    if (anyD){
      html+=`
        <div class="dsection">
          <div class="dsection-title">💵 สรุปธนบัตร/เหรียญที่รับมา</div>
          <div class="dgrid">
            ${BANKNOTES.map(d=>totD[d]>0?`
              <div class="dcell note">
                <div class="dval">฿${fmt(d)}</div>
                <div class="dcnt">${totD[d]} ใบ</div>
                <div class="dtot">= ฿${fmt(d*totD[d])}</div>
              </div>`:``).join('')}
            ${COINS.map(d=>totD[d]>0?`
              <div class="dcell coin">
                <div class="dval">฿${fmt(d)}</div>
                <div class="dcnt">${totD[d]} เหรียญ</div>
                <div class="dtot">= ฿${fmt(d*totD[d])}</div>
              </div>`:``).join('')}
          </div>
        </div>
      `;
    }
  }

  // Monthly breakdown
  if (tab==='all'||tab==='month'){
    const byMonth={};
    recs.forEach(r=>{
      const m=r.time.slice(0,7);
      if(!byMonth[m]) byMonth[m]={total:0,cash:0,transfer:0,cnt:0};
      byMonth[m].total+=r.total; byMonth[m].cnt++;
      if(r.paymentType==='cash') byMonth[m].cash+=r.total;
      else byMonth[m].transfer+=r.total;
    });
    const months=Object.keys(byMonth).sort().reverse();
    html+=`
      <table class="day-table">
        <thead><tr><th>เดือน</th><th>ยอดรวม</th><th>เงินสด</th><th>เงินโอน</th><th>จำนวน</th></tr></thead>
        <tbody>
          ${months.map(m=>`
            <tr>
              <td class="td-date" onclick="jumpToMonth('${m}')">${m}</td>
              <td class="td-total">฿${fmt(byMonth[m].total)}</td>
              <td class="td-cash">฿${fmt(byMonth[m].cash)}</td>
              <td class="td-tf">฿${fmt(byMonth[m].transfer)}</td>
              <td>${byMonth[m].cnt}</td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;
    if (tab==='all') { content.innerHTML=html; return; }
  }

  // Daily breakdown
  if (tab==='month'){
    const byDay={};
    recs.forEach(r=>{
      const d=r.time.slice(0,10);
      if(!byDay[d]) byDay[d]={total:0,cash:0,transfer:0,cnt:0};
      byDay[d].total+=r.total; byDay[d].cnt++;
      if(r.paymentType==='cash') byDay[d].cash+=r.total;
      else byDay[d].transfer+=r.total;
    });
    const days=Object.keys(byDay).sort().reverse();
    html+=`
      <table class="day-table">
        <thead><tr><th>วัน</th><th>ยอดรวม</th><th>เงินสด</th><th>เงินโอน</th><th>จำนวน</th></tr></thead>
        <tbody>
          ${days.map(d=>`
            <tr>
              <td class="td-date" onclick="jumpToDay('${d}')">${d}</td>
              <td class="td-total">฿${fmt(byDay[d].total)}</td>
              <td class="td-cash">฿${fmt(byDay[d].cash)}</td>
              <td class="td-tf">฿${fmt(byDay[d].transfer)}</td>
              <td>${byDay[d].cnt}</td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;
  }

  // Individual records
  html+=`
    <div>
      <div class="slabel" style="margin-bottom:8px">🧾 รายการทั้งหมด (${recs.length} รายการ)</div>
      <div class="hitems">
        ${recs.map(r=>{
          const t=new Date(r.time);
          const timeStr=t.toLocaleDateString('th-TH',{day:'numeric',month:'short'})+' · '+
            t.toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit',hour12:false});
          const icon=r.paymentType==='cash'?'💵':'📱';
          const cls=r.paymentType==='cash'?'cash':'transfer';
          const goods=r.items.map(i=>`${i.name}×${i.qty}`).join(', ');
          return `
            <div class="hitem">
              <div class="hitem-badge ${cls}">${icon}</div>
              <div class="hitem-info">
                <div class="hitem-goods">${esc(goods)}</div>
                <div class="hitem-time">${timeStr} · ${r.paymentType==='cash'?'เงินสด':'เงินโอน'}</div>
              </div>
              <div class="hitem-amt">฿${fmt(r.total)}</div>
            </div>
          `;
        }).join('')}
      </div>
    </div>
  `;

  content.innerHTML=html;
}

function jumpToDay(dateStr){
  document.getElementById('dayPicker').value=dateStr;
  switchTab('day');
}
function jumpToMonth(m){
  document.getElementById('monthPicker').value=m;
  switchTab('month');
}

// ==================== EXPORT CSV ====================
function exportCSV(){
  const tab=currentTab;
  let prefix='';
  if(tab==='today') prefix=new Date().toISOString().slice(0,10);
  else if(tab==='day') prefix=document.getElementById('dayPicker').value;
  else if(tab==='month') prefix=document.getElementById('monthPicker').value;
  const recs=getRecords(prefix);
  if(!recs.length){alert('ไม่มีข้อมูลในช่วงเวลานี้');return;}
  const rows=[
    ['วันที่','เวลา','สินค้า','ยอดรวม','วิธีชำระ','เงินที่รับมา','เงินทอน',
     '฿1000','฿500','฿100','฿50','฿20','฿10','฿5','฿2','฿1']
  ];
  recs.forEach(r=>{
    const t=new Date(r.time);
    const dateStr=t.toLocaleDateString('th-TH',{day:'2-digit',month:'2-digit',year:'numeric'});
    const timeStr=t.toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit',hour12:false});
    const goods=r.items.map(i=>`${i.name}×${i.qty}`).join('; ');
    const d=r.cashDenominations||{};
    rows.push([
      dateStr,timeStr,goods,r.total,
      r.paymentType==='cash'?'เงินสด':'เงินโอน',
      r.received,r.change,
      d[1000]||0,d[500]||0,d[100]||0,d[50]||0,d[20]||0,
      d[10]||0,d[5]||0,d[2]||0,d[1]||0
    ]);
  });
  const csv='\uFEFF'+rows.map(r=>r.map(c=>`"${String(c).replace(/"/g,'""')}"`).join(',')).join('\r\n');
  const blob=new Blob([csv],{type:'text/csv;charset=utf-8'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url;a.download=`pos_export_${prefix||'all'}_${Date.now()}.csv`;
  a.click();URL.revokeObjectURL(url);
  showToast('📥 Export สำเร็จแล้ว!');
}

