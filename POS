
<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>POS คิดเงิน</title>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #F4EFE6;
  --surface: #FFFFFF;
  --surface2: #FAF7F2;
  --border: #DDD5C8;
  --text: #1C1710;
  --muted: #9A8E82;
  --accent: #D95F0A;
  --accent-h: #B84E08;
  --accent-l: #FEF0E6;
  --green: #1A9460;
  --green-h: #157A4E;
  --green-l: #E5F6EE;
  --blue: #1B6ACE;
  --blue-l: #E5EFFE;
  --red: #CC3B1B;
  --red-l: #FDEBE6;
  --yellow: #D4890A;
  --yellow-l: #FEF5E6;
  --r: 14px;
  --rs: 10px;
  --sh: 0 2px 8px rgba(0,0,0,0.08);
  --sh2: 0 6px 24px rgba(0,0,0,0.13);
}

/* ========== RESET ========== */
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html{height:100%}
body{font-family:'Sarabun',sans-serif;background:var(--bg);color:var(--text);height:100dvh;display:grid;grid-template-rows:auto 1fr;overflow:hidden}

/* ========== HEADER ========== */
.hdr{background:var(--text);color:#fff;height:48px;padding:0 12px;display:flex;align-items:center;justify-content:space-between;gap:8px;z-index:10}
.hdr-logo{font-size:18px;font-weight:900;letter-spacing:-0.5px;white-space:nowrap}
.hdr-logo span{color:var(--accent)}
.hdr-clock{font-size:15px;font-weight:800;color:rgba(255,255,255,0.6);font-variant-numeric:tabular-nums;white-space:nowrap;flex:1;text-align:center}
.hdr-btns{display:flex;gap:6px;flex-shrink:0}
.hbtn{background:rgba(255,255,255,0.12);border:2px solid rgba(255,255,255,0.18);color:#fff;padding:6px 12px;border-radius:9px;font-family:'Sarabun',sans-serif;font-size:13px;font-weight:800;cursor:pointer;transition:background 0.15s;white-space:nowrap}
.hbtn:hover,.hbtn:active{background:rgba(255,255,255,0.22)}
.hbtn.acc{background:var(--accent);border-color:var(--accent)}
.hbtn.acc:hover{background:var(--accent-h)}

/* ========== BACKUP INDICATOR ========== */
.backup-dot{width:7px;height:7px;border-radius:50%;display:inline-block;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}

/* ========== MAIN LAYOUT ========== */
/* body row 2 = main; split left + right */
.main{
  display:grid;
  grid-template-columns:1fr 320px;
  overflow:hidden;
  min-height:0;
}

/* ========== LEFT PANEL — fixed grid rows, NO scroll ever ========== */
.lpanel{
  display:grid;
  /* rows: price-grid | payment-btns | denom section */
  grid-template-rows:auto auto 1fr;
  overflow:hidden;
  padding:8px;
  gap:6px;
  min-height:0;
}
/* alias for the scrollable wrapper — no longer scrolls */
.lpanel-scroll{
  display:contents; /* children participate in lpanel grid directly */
}

/* price section = auto height */
.price-section{ min-height:0; }

/* payment section = auto height */
.payment-section{ min-height:0; }

/* cash section fills remaining space */
#cashSection{
  display:grid;
  grid-template-rows:auto 1fr; /* label + denom-wrap */
  min-height:0;
  overflow:hidden;
}
#transferSection{
  display:flex;flex-direction:column;justify-content:center;
}

/* denom-wrap = fixed grid inside cashSection row 2 */
.denom-wrap{
  background:var(--surface);border:2px solid var(--border);border-radius:var(--r);
  padding:8px;box-shadow:var(--sh);
  display:grid;
  /* rows: banknote-label | banknote-grid | coin-label | coin-grid | manual-toggle | [manual-input] | breakdown | divider+total | change */
  grid-template-rows:auto auto auto auto auto auto 1fr auto auto;
  gap:5px;
  overflow:hidden;
  min-height:0;
}

/* ========== SECTION LABEL ========== */
.slabel{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;color:var(--muted);margin-bottom:3px;flex-shrink:0}

/* ========== PRICE GRID ========== */
.pgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:5px}
.pbtn{
  background:var(--surface);border:2px solid var(--border);border-radius:12px;
  padding:0 4px;
  font-family:'Sarabun',sans-serif;font-size:19px;font-weight:900;color:var(--text);
  cursor:pointer;transition:all 0.1s;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1px;
  box-shadow:var(--sh);height:58px;touch-action:manipulation;
}
.pbtn .sub{font-size:10px;font-weight:700;color:var(--muted)}
.pbtn:hover{border-color:var(--accent);background:var(--accent-l);color:var(--accent)}
.pbtn:active{transform:scale(0.92)}
.pbtn.hi{background:var(--accent-l);border-color:var(--accent);color:var(--accent)}
.pbtn.hi .sub{color:var(--accent);opacity:0.7}
.pcustom{
  grid-column:span 2;background:var(--text);border:2px solid var(--text);border-radius:12px;
  padding:0 12px;font-family:'Sarabun',sans-serif;font-size:15px;font-weight:900;color:#fff;
  cursor:pointer;transition:all 0.1s;
  display:flex;align-items:center;justify-content:center;gap:7px;
  height:58px;box-shadow:var(--sh);touch-action:manipulation;
}
.pcustom:hover{background:#2d2820}
.pcustom:active{transform:scale(0.96)}

/* ========== PAYMENT TYPE ========== */
.ptype{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.ptbtn{
  border:2px solid var(--border);border-radius:12px;padding:10px;
  font-family:'Sarabun',sans-serif;font-size:17px;font-weight:900;
  cursor:pointer;transition:all 0.15s;
  display:flex;align-items:center;justify-content:center;gap:8px;
  background:var(--surface);color:var(--muted);touch-action:manipulation;
}
.ptbtn.ac{background:var(--green-l);border-color:var(--green);color:var(--green)}
.ptbtn.at{background:var(--blue-l);border-color:var(--blue);color:var(--blue)}

/* ========== DENOM GRID ========== */
.denom-sub-label{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;line-height:1}
.denom-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:5px}
.denom-grid.coins{grid-template-columns:repeat(4,1fr)}
.dbtn{
  position:relative;background:var(--surface2);border:2px solid var(--border);border-radius:9px;
  padding:6px 4px;text-align:center;cursor:pointer;transition:all 0.1s;
  height:52px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1px;
  user-select:none;touch-action:manipulation;
}
.dbtn .dv{font-size:15px;font-weight:900;line-height:1}
.dbtn .dt{font-size:10px;color:var(--muted);font-weight:600}
.dbtn:hover{border-color:var(--accent);background:var(--accent-l)}
.dbtn:active{transform:scale(0.90)}
.dbadge{position:absolute;top:-7px;right:-7px;background:var(--accent);color:#fff;width:20px;height:20px;border-radius:50%;display:none;align-items:center;justify-content:center;font-size:11px;font-weight:900;border:2px solid var(--surface)}
.dbadge.show{display:flex}

/* ========== BREAKDOWN ========== */
.denom-breakdown{display:flex;flex-direction:column;gap:3px;overflow-y:auto;min-height:0}
.denom-row{display:flex;align-items:center;justify-content:space-between;background:var(--surface2);border-radius:7px;padding:4px 8px;animation:slideIn 0.2s ease;flex-shrink:0}
.denom-row-left{display:flex;align-items:center;gap:6px}
.denom-row-info{font-size:14px;font-weight:700}
.denom-row-total{font-size:14px;font-weight:800;font-variant-numeric:tabular-nums}
.denom-row-minus{background:none;border:1.5px solid var(--border);border-radius:6px;width:26px;height:26px;cursor:pointer;font-size:15px;font-weight:800;color:var(--muted);display:flex;align-items:center;justify-content:center;transition:all 0.1s;flex-shrink:0}
.denom-row-minus:hover{border-color:var(--red);color:var(--red);background:var(--red-l)}
.denom-empty{text-align:center;color:var(--muted);font-size:12px;padding:4px 0}

/* ========== TOTAL RECEIVED ========== */
.denom-total-row{display:flex;justify-content:space-between;align-items:center;padding-top:4px;border-top:2px solid var(--border);flex-shrink:0}
.denom-total-label{font-size:13px;font-weight:700;color:var(--muted)}
.denom-total-val{font-size:20px;font-weight:900;font-variant-numeric:tabular-nums}

/* ========== MANUAL INPUT ========== */
.denom-manual-toggle{background:none;border:1.5px solid var(--border);border-radius:7px;padding:5px 10px;font-family:'Sarabun',sans-serif;font-size:12px;font-weight:700;color:var(--muted);cursor:pointer;width:100%;transition:all 0.15s;flex-shrink:0}
.denom-manual-toggle:hover{background:var(--surface2)}
.manual-input{border:2px solid var(--border);border-radius:var(--rs);padding:7px 12px;font-family:'Sarabun',sans-serif;font-size:20px;font-weight:800;color:var(--text);outline:none;background:var(--surface2);width:100%;text-align:right;flex-shrink:0}
.manual-input:focus{border-color:var(--accent);background:#fff}

/* ========== CHANGE BOX — always last row in denom-wrap grid ========== */
.change-box{
  display:flex;justify-content:space-between;align-items:center;
  padding:10px 14px;
  background:var(--green-l);border-radius:var(--rs);border:2px solid var(--green);
  flex-shrink:0;
}
.change-box.ins{background:var(--red-l);border-color:var(--red)}
.change-box.zero{background:var(--surface2);border-color:var(--border)}
.change-lbl{font-size:16px;font-weight:800;color:var(--green)}
.change-box.ins .change-lbl{color:var(--red)}
.change-box.zero .change-lbl{color:var(--muted)}
.change-val{font-size:28px;font-weight:900;color:var(--green);font-variant-numeric:tabular-nums}
.change-box.ins .change-val{color:var(--red)}
.change-box.zero .change-val{color:var(--muted)}

/* ========== TRANSFER BOX ========== */
.transfer-box{background:var(--blue-l);border:2px solid var(--blue);border-radius:var(--r);padding:16px;text-align:center}
.transfer-box .ti{font-size:28px;margin-bottom:4px}
.transfer-box .tl{font-size:17px;font-weight:900;color:var(--blue)}
.transfer-box .ts{font-size:12px;color:var(--blue);opacity:0.7;margin-top:3px}

/* ========== CART ========== */
.rpanel{
  background:var(--surface);border-left:2px solid var(--border);
  display:grid;grid-template-rows:auto 1fr auto;
  overflow:hidden;min-height:0;
}
.cart-hdr{padding:10px 14px 8px;border-bottom:2px solid var(--border)}
.cart-hdr{display:flex;justify-content:space-between;align-items:center;}
.cart-title{font-size:15px;font-weight:900}
.btn-clr{background:var(--red-l);color:var(--red);border:none;padding:7px 12px;border-radius:8px;font-family:'Sarabun',sans-serif;font-size:13px;font-weight:700;cursor:pointer}
.btn-clr:hover{background:#f5c2bb}
.cart-list{overflow-y:auto;padding:5px 12px;min-height:0}
.cart-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:var(--muted);gap:7px}
.cart-empty .ei{font-size:36px}
.cart-empty p{font-size:15px;font-weight:700}
.cart-empty .es{font-size:12px}
.citem{display:flex;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);gap:7px;animation:slideIn 0.2s ease}
@keyframes slideIn{from{opacity:0;transform:translateX(8px)}to{opacity:1;transform:none}}
.citem-info{flex:1;min-width:0}
.citem-name{font-size:14px;font-weight:900;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.citem-price{font-size:12px;color:var(--muted);font-variant-numeric:tabular-nums}
.cqty{display:flex;align-items:center;gap:5px}
.qbtn{width:28px;height:28px;border-radius:7px;border:2px solid var(--border);background:var(--surface2);font-size:15px;font-weight:900;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text);touch-action:manipulation}
.qbtn:hover{background:var(--border)}
.qnum{font-size:14px;font-weight:900;min-width:22px;text-align:center;font-variant-numeric:tabular-nums}
.citem-tot{font-size:14px;font-weight:900;min-width:56px;text-align:right;font-variant-numeric:tabular-nums}
.rmbtn{background:none;border:none;color:var(--muted);font-size:15px;cursor:pointer;padding:3px;transition:color 0.1s;line-height:1}
.rmbtn:hover{color:var(--red)}

/* CART FOOTER */
.cart-foot{border-top:2px solid var(--border);padding:10px 14px;background:var(--surface2)}
.tot-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.tot-lbl{font-size:15px;font-weight:700;color:var(--muted)}
.tot-amt{font-size:34px;font-weight:900;font-variant-numeric:tabular-nums}
.tot-cur{font-size:15px;font-weight:700;color:var(--muted);margin-left:3px}
.checkout-btn{
  width:100%;background:var(--accent);color:#fff;border:none;border-radius:var(--r);
  padding:15px;font-family:'Sarabun',sans-serif;font-size:19px;font-weight:900;
  cursor:pointer;transition:all 0.15s;
  display:flex;align-items:center;justify-content:center;gap:8px;
  box-shadow:0 4px 14px rgba(217,95,10,0.35);touch-action:manipulation;
}
.checkout-btn:hover{background:var(--accent-h)}
.checkout-btn:active{transform:scale(0.97)}
.checkout-btn:disabled{background:var(--border);color:var(--muted);box-shadow:none;cursor:default}

/* ========== MODALS ========== */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:100;align-items:center;justify-content:center;padding:12px;backdrop-filter:blur(4px)}
.overlay.open{display:flex}
.modal{background:var(--surface);border-radius:18px;width:100%;max-width:520px;max-height:92dvh;overflow:hidden;display:flex;flex-direction:column;box-shadow:var(--sh2);animation:mIn 0.25s cubic-bezier(0.34,1.56,0.64,1)}
.modal.wide{max-width:700px}
@keyframes mIn{from{opacity:0;transform:scale(0.88) translateY(16px)}to{opacity:1;transform:none}}
.mhdr{padding:16px 16px 12px;display:flex;justify-content:space-between;align-items:center;border-bottom:2px solid var(--border);flex-shrink:0}
.mtitle{font-size:18px;font-weight:900}
.mclose{background:var(--surface2);border:2px solid var(--border);width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;color:var(--muted);font-weight:700}
.mclose:hover{background:var(--border);color:var(--text)}
.mbody{padding:14px;overflow-y:auto;flex:1}

/* NUMPAD */
.ndisp{background:var(--surface2);border:2px solid var(--border);border-radius:var(--rs);padding:12px;font-size:32px;font-weight:900;text-align:right;margin-bottom:4px;font-variant-numeric:tabular-nums;min-height:58px;display:flex;align-items:center;justify-content:flex-end}
.nlabel{font-size:11px;color:var(--muted);font-weight:700;text-align:right;margin-bottom:6px}
.npad{display:grid;grid-template-columns:repeat(3,1fr);gap:7px}
.nbtn{border:2px solid var(--border);border-radius:var(--rs);padding:16px;font-family:'Sarabun',sans-serif;font-size:20px;font-weight:800;cursor:pointer;background:var(--surface);transition:all 0.1s;color:var(--text);touch-action:manipulation}
.nbtn:hover{background:var(--surface2);border-color:#bbb}
.nbtn:active{transform:scale(0.91);background:var(--border)}
.nbtn.del{background:var(--red-l);color:var(--red);border-color:var(--red-l)}
.nbtn.ok{background:var(--green);color:#fff;border-color:var(--green);font-size:16px;grid-column:span 2}
.nbtn.ok:hover{background:var(--green-h)}
.nbtn.z2{grid-column:span 2}

/* HISTORY */
.htabs{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap}
.htab{border:2px solid var(--border);border-radius:8px;padding:7px 14px;font-family:'Sarabun',sans-serif;font-size:14px;font-weight:800;cursor:pointer;background:var(--surface2);color:var(--muted);transition:all 0.15s;white-space:nowrap}
.htab.active{background:var(--text);color:#fff;border-color:var(--text)}
.hdate-input{border:2px solid var(--border);border-radius:var(--rs);padding:8px 12px;font-family:'Sarabun',sans-serif;font-size:15px;font-weight:700;color:var(--text);outline:none;background:var(--surface2)}
.hdate-input:focus{border-color:var(--accent);background:#fff}
.hdate-row{display:flex;gap:8px;align-items:center;margin-bottom:12px;flex-wrap:wrap}
.hdate-row .slabel{margin-bottom:0;white-space:nowrap}
.scards{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:12px}
.scard{border-radius:var(--r);padding:12px;border:2px solid var(--border)}
.scard.tot{background:var(--accent-l);border-color:var(--accent)}
.scard.csh{background:var(--green-l);border-color:var(--green)}
.scard.trf{background:var(--blue-l);border-color:var(--blue)}
.scard-lbl{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:2px}
.scard.tot .scard-lbl{color:var(--accent)}
.scard.csh .scard-lbl{color:var(--green)}
.scard.trf .scard-lbl{color:var(--blue)}
.scard-amt{font-size:20px;font-weight:900;font-variant-numeric:tabular-nums;line-height:1.1}
.scard.tot .scard-amt{color:var(--accent)}
.scard.csh .scard-amt{color:var(--green)}
.scard.trf .scard-amt{color:var(--blue)}
.scard-sub{font-size:11px;color:var(--muted);margin-top:1px}
.dsection{background:var(--surface2);border:1.5px solid var(--border);border-radius:var(--r);padding:10px;margin-bottom:10px}
.dsection-title{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:8px}
.dgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(88px,1fr));gap:6px}
.dcell{background:var(--surface);border:1.5px solid var(--border);border-radius:9px;padding:8px 6px;text-align:center}
.dcell .dval{font-size:14px;font-weight:900}
.dcell .dcnt{font-size:11px;color:var(--muted);font-weight:700}
.dcell .dtot{font-size:10px;color:var(--accent);font-weight:800;margin-top:2px;font-variant-numeric:tabular-nums}
.dcell.note{border-color:var(--yellow);background:var(--yellow-l)}
.dcell.note .dval{color:var(--yellow)}
.dcell.coin{border-color:var(--muted)}
.dcell.coin .dval{color:var(--muted)}
.day-table{width:100%;border-collapse:collapse;margin-bottom:10px}
.day-table th{text-align:left;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:0.8px;color:var(--muted);padding:6px 8px;border-bottom:2px solid var(--border)}
.day-table td{padding:9px 8px;border-bottom:1px solid var(--border);font-size:13px;font-weight:600;font-variant-numeric:tabular-nums}
.day-table tr:hover td{background:var(--surface2)}
.day-table .td-date{font-weight:800;cursor:pointer;color:var(--accent);text-decoration:underline}
.day-table .td-total{font-weight:900;font-size:14px}
.day-table .td-cash{color:var(--green);font-weight:700}
.day-table .td-tf{color:var(--blue);font-weight:700}
.hitems{display:flex;flex-direction:column;gap:1px}
.hitem{display:flex;align-items:center;padding:9px 0;border-bottom:1px solid var(--border);gap:9px}
.hitem-badge{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.hitem-badge.cash{background:var(--green-l)}
.hitem-badge.transfer{background:var(--blue-l)}
.hitem-info{flex:1;min-width:0}
.hitem-goods{font-size:12px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hitem-time{font-size:11px;color:var(--muted);margin-top:1px}
.hitem-amt{font-size:15px;font-weight:900;font-variant-numeric:tabular-nums;white-space:nowrap}
.hempty{text-align:center;color:var(--muted);padding:32px 0;font-size:14px;font-weight:600}
.hperiod-title{font-size:14px;font-weight:900;margin-bottom:8px;padding-bottom:7px;border-bottom:2px solid var(--border)}
.info-box{background:var(--yellow-l);border:1.5px solid var(--yellow);border-radius:var(--r);padding:12px;margin-bottom:10px;font-size:12px;font-weight:600;color:#7A5500;line-height:1.5}
.info-box strong{font-weight:900}
.export-row{display:flex;gap:7px;margin-bottom:12px}
.ebtn{flex:1;background:var(--surface2);border:2px solid var(--border);border-radius:var(--rs);padding:9px;font-family:'Sarabun',sans-serif;font-size:13px;font-weight:700;cursor:pointer;color:var(--text);transition:all 0.15s;display:flex;align-items:center;justify-content:center;gap:5px}
.ebtn:hover{background:var(--border)}
.ebtn.del-all{color:var(--red);border-color:var(--red-l);background:var(--red-l)}
.ebtn.del-all:hover{background:#f5c2bb}
.sdivider{height:1px;background:var(--border);margin:8px 0}

/* ========== TOAST ========== */
