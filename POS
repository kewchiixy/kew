  const tab=currentTab;
  let prefix='',label='ทั้งหมด';
  if(tab==='today'){prefix=new Date().toISOString().slice(0,10);label='วันนี้';}
  else if(tab==='day'){prefix=document.getElementById('dayPicker').value;label='วันที่เลือก';}
  else if(tab==='month'){prefix=document.getElementById('monthPicker').value;label='เดือนที่เลือก';}
  if(!confirm(`ลบข้อมูล${label}ทั้งหมด? ไม่สามารถกู้คืนได้`)) return;
